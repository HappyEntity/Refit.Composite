root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.cs]

csharp_style_prefer_primary_constructors = true:suggestion
csharp_style_spacing_after_primary_constructor_parameters_arrow = true

csharp_style_namespace_declarations = file_scoped:warning

csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion

csharp_style_expression_bodied_properties = true:suggestion
csharp_style_expression_bodied_methods = false:silent

csharp_style_prefer_switch_expression = true:suggestion

dotnet_diagnostic.IDE0130.severity = none

csharp_new_line_before_open_brace = types, methods, properties
csharp_new_line_before_else = true
csharp_new_line_before_catch = true

dotnet_naming_rule.interface_should_be_begun_with_i.severity = warning
dotnet_naming_rule.interface_should_be_begun_with_i.symbols = interface_symbols
dotnet_naming_rule.interface_should_be_begun_with_i.style = i_prefix_style

dotnet_naming_symbols.interface_symbols.applicable_kinds = interface
dotnet_naming_style.i_prefix_style.required_prefix = I
dotnet_naming_style.i_prefix_style.capitalization = pascal_case